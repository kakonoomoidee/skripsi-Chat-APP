# ==========================================
# CLIENT CONFIGURATION (VITE)
# ==========================================
# The HTTP endpoint of your Relay Server.
# If running locally, this should match the relay-server PORT.
VITE_API_URL="http://localhost:3001"

# The Web3 RPC endpoint for blockchain interactions.
# Match this with your Ganache port (e.g., 7545 for dev, 8545 for prod) or Infura URL.
VITE_RPC_URL="http://127.0.0.1:7545"