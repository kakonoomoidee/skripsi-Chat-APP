# Server Configuration
PORT=3001

# Public URL of this relay (used for self-registration). Defaults to http://localhost:PORT
# RELAY_PUBLIC_URL=https://your-relay-domain.com

# Blockchain Configuration (Ganache)
RPC_URL="http://127.0.0.1:7545"

# Smart Contract Address (auto generated, replace with actual address after deployment)
CONTRACT_ADDRESS="0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Relay Registry Contract Address
RELAY_REGISTRY_ADDRESS="0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Relayer Private Key (Gas Payer)
RELAYER_PRIVATE_KEY="0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Security (JWT Secret) - use a long random string in production
# Generate with: openssl rand -hex 32
JWT_SECRET="replace_with_output_of_openssl_rand_hex_32"

# Shared secret for inter-relay gossip authentication (use a long random string)
# Generate with: openssl rand -hex 32
# NOTE: All relays in the same cluster MUST share the same INTERNAL_SECRET value.
#       If set on any relay, all other relays communicating with it must also set the same value.
# If not set, gossip endpoint is unauthenticated (not safe for production)
# INTERNAL_SECRET="replace_with_output_of_openssl_rand_hex_32"

# Comma-separated list of allowed client origins (e.g. http://localhost:5173,https://app.example.com)
# Leave empty to block all cross-origin requests
ALLOWED_ORIGINS="http://localhost:5173"