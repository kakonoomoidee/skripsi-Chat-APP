# ==========================================
# SERVER SETTINGS
# ==========================================
# The port on which the relay server will run.
PORT=3001

# CORS configuration: Comma-separated list of allowed frontend URLs.
ALLOWED_ORIGINS="http://localhost:5173"

# ==========================================
# SECURITY & AUTHENTICATION
# ==========================================
# Secret key for signing JWT tokens. 
# Generate a secure one using terminal: openssl rand -hex 32
JWT_SECRET="your_secure_jwt_secret_hex_here"

# ==========================================
# BLOCKCHAIN INTEGRATION
# ==========================================
# The Web3 RPC endpoint (Ganache, Infura, etc.).
RPC_URL="http://127.0.0.1:7545"

# The deployed Identity Registry smart contract address.
# Copy this from Truffle migration output after deployment.
CONTRACT_ADDRESS="0x_your_identity_registry_contract_address"

# The deployed Relay Registry smart contract address.
RELAY_REGISTRY_ADDRESS="0x_your_relay_registry_contract_address"

# ==========================================
# GASLESS META-TRANSACTIONS
# ==========================================
# The private key of the wallet that will pay for user registration gas fees.
# In Ganache, copy a private key from one of the available test accounts.
RELAYER_PRIVATE_KEY="0x_your_relayer_private_key"