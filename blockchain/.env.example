# ==========================================
# WALLET & NETWORK PROVIDER
# ==========================================
# Your 12-word mnemonic phrase (e.g., from Ganache or MetaMask).
# WARNING: Do not use a mnemonic with real funds for development!
MNEMONIC="test test test test test test test test test test test junk"

# Your Infura or Alchemy Project ID for public network deployments.
# Get this from: https://infura.io/
INFURA_PROJECT_ID="your_infura_project_id_here"

# ==========================================
# LOCAL DEVELOPMENT (GANACHE)
# ==========================================
# Standard local Ganache GUI/CLI settings.
DEV_HOST="127.0.0.1"
DEV_PORT="7545"
DEV_NETWORK_ID="*"

# Production simulation Ganache settings.
PROD_HOST="127.0.0.1"
PROD_PORT="8545"
PROD_NETWORK_ID="*"

# ==========================================
# PUBLIC NETWORKS
# ==========================================
SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/your_infura_project_id_here"
MAINNET_RPC_URL="https://mainnet.infura.io/v3/your_infura_project_id_here"